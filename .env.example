# 数据源配置
# API-FOOTBALL 赛程/赛果接口 Key，未接入时可留空
API_FOOTBALL_KEY=
# Sportmonks 等赔率/数据源 Token，未接入时可留空
SPORTMONKS_API_TOKEN=
# Serper 网页检索 Key，用于赛前资料检索；留空则跳过真实网页检索
SERPER_API_KEY=

# DeepSeek 通用模型配置
# DeepSeek API Key，只保存在本地 .env，不要提交到 Git
DEEPSEEK_API_KEY=
# 默认 DeepSeek 模型名
DEEPSEEK_MODEL=deepseek-v4-pro
# 是否开启 thinking 参数：enabled/disabled，按当前模型支持情况配置
DEEPSEEK_THINKING=enabled
# 通用推理强度：low/medium/high 等
DEEPSEEK_REASONING_EFFORT=high

# 后台访问配置
# Admin API Token，请求后台接口时放在 X-Admin-Token 头里
ADMIN_TOKEN=change-me
# /admin 页面进入密码，只保存在本地 .env
ADMIN_PAGE_PASSWORD=change-me

# 微信公众号草稿箱配置
# 公众号 AppID
WECHAT_APP_ID=
# 公众号 AppSecret，只保存在本地 .env，不要提交到 Git
WECHAT_APP_SECRET=
# 公众号文章作者名
WECHAT_AUTHOR=世界杯观赛助手
# 微信素材库中的默认封面 media_id，推送草稿箱必填
WECHAT_DEFAULT_COVER_MEDIA_ID=
# 公众号正文标题图本地文件；未配置微信正文图片 URL 时才会现场上传
WECHAT_ARTICLE_HERO_IMAGE_PATH=assets/wechat-article-hero-card.png
# 后台 HTML 预览使用的标题图地址；正式推草稿时不会直接使用本地地址
WECHAT_ARTICLE_HERO_IMAGE_PREVIEW_URL=/static/assets/wechat-article-hero-card.png
# 预先上传到微信正文图片接口后得到的 URL；配置后推草稿时直接复用，不再每日上传首图
WECHAT_ARTICLE_HERO_IMAGE_WECHAT_URL=
# 文章原文链接，通常指向世界杯预测网页
WECHAT_ARTICLE_SOURCE_URL=http://140.143.182.236/worldcup/
# 定时任务是否自动推送草稿箱；false 表示只生成，后台人工推送
WECHAT_DAILY_PREVIEW_AUTO_DRAFT=false
# 每日自动生成前瞻的小时，24 小时制
WECHAT_DAILY_PREVIEW_HOUR=18

# 公众号文章专用 DeepSeek 配置
# 公众号文章生成的推理强度，独立于单场报告
DEEPSEEK_WECHAT_REASONING_EFFORT=medium
# 公众号文章生成是否开启 thinking 参数
DEEPSEEK_WECHAT_THINKING=enabled
